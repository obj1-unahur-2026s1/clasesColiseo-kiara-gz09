import armas.*
import gladiadores.*

test "Un dimachaerus crea un grupo D-X" {
    const dim1 = new Dimachaerus(destreza = 10)
    dim1.arma().add(new ArmaContundente(peso = 10))

    const dim2 = new Dimachaerus(destreza = 20)
    dim2.arma().add(new ArmaContundente(peso = 20))

    const grupo = dim1.crearGrupoCon(dim2)

    assert.equals(
        "D-50",
        grupo.nombre()
    )
}